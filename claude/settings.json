{
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:pytorch.org)",
      "WebFetch(domain:botorch.org)",
      "WebFetch(domain:gpytorch.readthedocs.io)",
      "WebFetch(domain:hydra.cc)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:huggingface.co)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:wandb.ai)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "ask": [
      "Bash(pip *)",
      "Bash(conda install *)",
      "Bash(conda create *)",
      "Bash(conda remove *)",
      "Bash(npm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(git push *)",
      "Bash(git stash drop *)",
      "Bash(brew *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(git rebase *)"
    ],
    "deny": [
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git clean -f *)",
      "Bash(git branch -D *)",
      "Bash(git checkout -- .)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(sudo *)",
      "Bash(chmod -R *)",
      "Bash(chown *)",
      "Bash(python -m http.server*)",
      "Bash(ngrok *)",
      "Bash(launchctl *)",
      "Bash(defaults write *)",
      "Bash(diskutil *)"
    ],
    "additionalDirectories": [
      "/tmp",
      "~/research",
      "~/workspace"
    ]
  }
}
